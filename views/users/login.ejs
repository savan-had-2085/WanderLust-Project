<% layout("/layouts/boilerplate") -%>
<div class="row mt-3">
    <h1 class="col-8 offset-3">Login on WanderLust</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="post" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="username" class="form-label">Enter Username</label>
                <input type="text" id="username" name="username" placeholder="Enter username" class="form-control" required>
                <div class="valid-feedback">Looks good!</div>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Enter Password</label>
                <input type="password" id="password" name="password" placeholder="Enter email" class="form-control" required>
                <div class="valid-feedback">Looks good!</div>
            </div>
            <!-- <br><br> -->
            <button class="btn btn-success mt-3">Login</button>
            <!-- <br><br> -->
        </form>
    </div>
</div>